{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemap.js",
    "sync-blog": "node -e \"const fs = require('fs'); fs.copyFileSync('../backend/blogData.json', './src/blogPosts.json')\"",
    "build": "npm run sync-blog && npm run sitemap && vite-ssg build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.0",
    "pinia": "^3.0.4",
    "pusher-js": "^8.5.0",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "vue3-google-signin": "^2.1.1"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.24.2",
    "@rolldown/binding-linux-x64-gnu": "0.13.2",
    "lightningcss-linux-x64-gnu": "^1.29.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
