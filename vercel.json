{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/es", "permanent": true },
    { "source": "/blog/:slug", "destination": "/es/blog/:slug", "permanent": true },
    { "source": "/contador-flexiones", "destination": "/es/contador-flexiones", "permanent": true },
    { "source": "/contador-dominadas", "destination": "/es/contador-dominadas", "permanent": true },
    { "source": "/app-calistenia", "destination": "/es/app-calistenia", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/favicon.ico", "destination": "/favicon.svg" },
    { "source": "/api/pusher/auth", "destination": "/api/pusher-auth.js" },
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/:lang(es|en)", "destination": "/:lang.html" },
    { "source": "/:lang(es|en)/blog", "destination": "/:lang/blog.html" },
    { "source": "/:lang(es|en)/blog/:slug", "destination": "/:lang/blog/:slug.html" },
    { "source": "/:lang(es|en)/contador-dominadas", "destination": "/:lang/contador-dominadas.html" },
    { "source": "/:lang(es|en)/contador-flexiones", "destination": "/:lang/contador-flexiones.html" },
    { "source": "/:lang(es|en)/app-calistenia", "destination": "/:lang/app-calistenia.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
